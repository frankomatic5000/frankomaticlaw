# ═══════════════════════════════════════════════════
# ENVIRONMENT VARIABLES — Frank + Jarbas
# GrowBiz Media · OpenClaw Platform
# ═══════════════════════════════════════════════════
# Copy this to .env and fill in your real values.
# NEVER commit .env to the repo.
# ═══════════════════════════════════════════════════

# ── Model Providers ─────────────────────────────────
OLLAMA_PRO_KEY=your_ollama_pro_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Channels ────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ── Integrations ────────────────────────────────────
QUICKBOOKS_CLIENT_ID=your_qb_client_id_here
QUICKBOOKS_CLIENT_SECRET=your_qb_client_secret_here
QUICKBOOKS_REFRESH_TOKEN=your_qb_refresh_token_here
QUICKBOOKS_REALM_ID=your_qb_realm_id_here

GITHUB_PAT=your_github_personal_access_token_here

# ── Email ───────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your_email@growbizmedia.com
EMAIL_PASSWORD=your_app_password_here

# ── Social Platforms ────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_token_here
TIKTOK_ACCESS_TOKEN=your_tiktok_token_here

# ── Budget ──────────────────────────────────────────
BUDGET_HARD_CAP=50
BUDGET_PAUSE_THRESHOLD=35
BUDGET_ABORT_THRESHOLD=48
GEMINI_WEEKLY_CAP=8

# ── Voice Transcription ────────────────────────────
WHISPER_MODEL=large-v3
WHISPER_LANGUAGES=pt,en